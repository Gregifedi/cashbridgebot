# -----------------------
# INIT DB
# -----------------------
def init_db():
    conn = sqlite3.connect(DB_PATH, timeout=10)
    cursor = conn.cursor()

    # Payments table
    cursor.execute("""
        CREATE TABLE IF NOT EXISTS payments (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            amount INTEGER,
            message TEXT,
            sender TEXT,
            reference TEXT UNIQUE,
            created_at TEXT
        )
    """)

    # Users table
    cursor.execute("""
        CREATE TABLE IF NOT EXISTS users (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            chat_id TEXT UNIQUE,
            username TEXT,
            email TEXT UNIQUE
        )
    """)

    conn.commit()
    conn.close()


# -----------------------
# SAVE PAYMENT
# -----------------------
def save_payment(amount, message, sender="unknown", reference=None):
    conn = sqlite3.connect(DB_PATH, timeout=10)
    cursor = conn.cursor()

    try:
        try:
            clean_amount = int(amount)
        except:
            clean_amount = None

        cursor.execute("""
            INSERT INTO payments (amount, message, sender, reference, created_at)
            VALUES (?, ?, ?, ?, ?)
        """, (
            clean_amount,
            message,
            sender,
            reference,
            datetime.utcnow().isoformat()
        ))

        conn.commit()

    except sqlite3.IntegrityError:
        print("Duplicate payment ignored:", reference)

    except Exception as e:
        print("Save payment error:", e)

    finally:
        conn.close()


# -----------------------
# SAVE USER
# -----------------------
def save_user(chat_id, username):
    conn = sqlite3.connect(DB_PATH, timeout=10)
    cursor = conn.cursor()

    try:
        cursor.execute("""
            INSERT OR IGNORE INTO users (chat_id, username)
            VALUES (?, ?)
        """, (chat_id, username))

        conn.commit()

    except Exception as e:
        print("Save user error:", e)

    finally:
        conn.close()


# -----------------------
# UPDATE USER EMAIL
# -----------------------
def update_user_email(chat_id, email):
    conn = sqlite3.connect(DB_PATH, timeout=10)
    cursor = conn.cursor()

    try:
        cursor.execute("""
            UPDATE users
            SET email = ?
            WHERE chat_id = ?
        """, (email, chat_id))

        conn.commit()

    except Exception as e:
        print("Update email error:", e)

    finally:
        conn.close()


# -----------------------
# GET USER BY EMAIL
# -----------------------
def get_user_by_email(email):
    conn = sqlite3.connect(DB_PATH, timeout=10)
    cursor = conn.cursor()

    try:
        cursor.execute("""
            SELECT chat_id FROM users WHERE email = ?
        """, (email,))

        result = cursor.fetchone()
        return result[0] if result else None

    except Exception as e:
        print("Get user error:", e)
        return None

    finally:
        conn.close()


# -----------------------
# TOTAL (ALL TIME)
# -----------------------
def get_total():
    conn = sqlite3.connect(DB_PATH, timeout=10)
    cursor = conn.cursor()

    try:
        cursor.execute("""
            SELECT COALESCE(SUM(amount), 0)
            FROM payments
            WHERE amount IS NOT NULL
        """)

        return cursor.fetchone()[0]

    finally:
        conn.close()


# -----------------------
# TODAY TOTAL
# -----------------------
def get_today_total():
    conn = sqlite3.connect(DB_PATH, timeout=10)
    cursor = conn.cursor()

    try:
        today = date.today().isoformat()

        cursor.execute("""
            SELECT COALESCE(SUM(amount), 0)
            FROM payments
            WHERE amount IS NOT NULL
            AND DATE(created_at) = ?
        """, (today,))

        return cursor.fetchone()[0]

    finally:
        conn.close()


# -----------------------
# COUNT PAYMENTS
# -----------------------
def get_count():
    conn = sqlite3.connect(DB_PATH, timeout=10)
    cursor = conn.cursor()

    try:
        cursor.execute("""
            SELECT COUNT(*)
            FROM payments
            WHERE amount IS NOT NULL
        """)

        return cursor.fetchone()[0]

    finally:
        conn.close()


# -----------------------
# TOP SENDER
# -----------------------
def get_top_sender():
    conn = sqlite3.connect(DB_PATH, timeout=10)
    cursor = conn.cursor()

    try:
        cursor.execute("""
            SELECT sender, SUM(amount) as total
            FROM payments
            WHERE amount IS NOT NULL
            GROUP BY sender
            ORDER BY total DESC
            LIMIT 1
        """)

        result = cursor.fetchone()

        if result:
            return result[0], result[1]

        return None, 0

    finally:
        conn.close()	

